FRAMEWORK_PORT=3000
FRAMEWORK_HOST=127.0.0.1
FRAMEWORK_BASE_PATH=

FRAMEWORK_JWT_SECRET=change-me-jwt-secret-32-chars-min
FRAMEWORK_JWT_EXPIRATION=7d

FRAMEWORK_COOKIES_SECRET=change-me-cookies-secret-32-chars
FRAMEWORK_COOKIES_CONFIG_SAME_SITE=none
FRAMEWORK_COOKIES_CONFIG_SECURE=true
FRAMEWORK_COOKIES_CONFIG_HTTP_ONLY=true

FRAMEWORK_ALLOWED_ORIGIN=http://localhost:5173,http://localhost:3000

APP_FRONTEND_URL=http://localhost:5173

APP_NAME=My App
APP_SUPPORT_EMAIL=support@example.com

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=nestjs_template
DATABASE_USERNAME=root
DATABASE_PASSWORD=secret

DATABASE_SYNCHRONIZE=false

DATABASE_HASH_SALT_ROUNDS=10

DATABASE_CRYPTOGRAPHY_METHOD=aes-256-cbc
DATABASE_CRYPTOGRAPHY_SECRET=32-char-secret-key-here-change-me
DATABASE_CRYPTOGRAPHY_IV=16-char-iv-here!

CACHE_STORAGE_HOST=localhost
CACHE_STORAGE_PORT=6379
CACHE_STORAGE_PASSWORD=

CACHE_STORAGE_CRYPTOGRAPHY_METHOD=aes-256-cbc
CACHE_STORAGE_CRYPTOGRAPHY_SECRET=32-char-secret-key-here-change-me
CACHE_STORAGE_CRYPTOGRAPHY_IV=16-char-iv-here!

EMAIL_TEMPLATE_DIR_RELATIVE_PATH=assets/email-template
EMAIL_SENDER=no-reply@example.com
EMAIL_SEND_GRID_KEY=SG.your-sendgrid-api-key-here

AUTHENTICATOR_APP_NAME=My App

BUCKET_S3_ENDPOINT=http://localhost:9000
BUCKET_S3_REGION=us-east-1
BUCKET_S3_ACCESS_KEY_ID=minioadmin
BUCKET_S3_ACCESS_KEY_CREDENTIAL=minioadmin
BUCKET_S3_BUCKET_NAME=nestjs-template

SIGNOZ_ENABLED=false
SIGNOZ_ENDPOINT=http://localhost:4318
SIGNOZ_SERVICE_NAME=nestjs-template
SIGNOZ_ACCESS_TOKEN=
