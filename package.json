{
  "name": "agiliza-previ-back",
  "version": "1.0.0",
  "description": "A AGILIZAPREV é uma solução SaaS voltada para análises previdenciárias, automatizando processos e integrando inteligência artificial para auxiliar advogados especializados em direito previdenciário.",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "22.15.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix --ignore-pattern \"src/migrations/**\"",
    "test": "yarn jest --config jest.config.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "ts-node -r tsconfig-paths/register src/cli/seed/seed.ts",
    "typeorm": "npm run build && npx typeorm -d dist/type-orm.config.js",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert"
  },
